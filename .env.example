# URL do webhook do n8n (server-only). Nunca use prefixo NEXT_PUBLIC_.
# Deve começar com https://. O script `npm run env:check` roda no prebuild
# e falha se a variável estiver ausente ou inválida.
N8N_WEBHOOK_URL=

# URL pública canônica do portfólio (usada para Origin allow-list, sitemap, OG).
NEXT_PUBLIC_SITE_URL=https://bps2414.vercel.app
